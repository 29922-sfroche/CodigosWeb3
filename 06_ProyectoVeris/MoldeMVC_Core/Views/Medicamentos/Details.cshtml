@model MoldeMVC_Core.Models.Medicamentos

@{
    ViewData["Title"] = "Detalle de medicamento";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Detalle de medicamento</h5>
    </div>
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3">Medicamento</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>
            <dt class="col-sm-3">Tipo</dt>
            <dd class="col-sm-9">@Model.Tipo</dd>
        </dl>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-list"></i> Volver</a>
        </div>
    </div>
</div>
