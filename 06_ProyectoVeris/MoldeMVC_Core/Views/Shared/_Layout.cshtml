<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VERIS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoldeMVC_Core.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg fixed-top shadow-sm"
             style="background:white; border-top:6px solid #35283a;">
            <div class="container-fluid px-5">

                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/Imagenes/Logo-Veris.png"
                         alt="VERIS"
                         style="height:62px; width:auto;" />
                </a>

                <button type="button" class="navbar-toggler"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center justify-content-center ms-5">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Pacientes" asp-action="Index">Pacientes</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicos" asp-action="Index">Médicos</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Consultas" asp-action="Index">Consultas</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Especialidades" asp-action="Index">Especialidades</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Recetas" asp-action="Index">Recetas</a>
                            </li>
                            <li class="nav-item mx-3">
                                <a class="nav-link text-primary fw-semibold" asp-area="" asp-controller="Medicamentos" asp-action="Index">Medicamentos</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item mx-3">
                                <a class="nav-link text-danger fw-semibold" asp-area="Identity" asp-page="/Account/Login">
                                    No autorizado. Iniciar Sesión
                                </a>
                            </li>
                        }

                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container body-content" style="padding-top:105px;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="text-white mt-5" style="background:#142946; border-top:8px solid #2f6df6;">
        <div class="container-fluid px-4 py-5">
            <div class="row gy-4 align-items-start">

                <div class="col-md-3">
                    <h5 class="fw-bold mb-3">Sobre nosotros</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2">Preguntas frecuentes</li>
                        <li class="mb-2">Deberes y derechos del paciente</li>
                        <li class="mb-2">Términos y condiciones</li>
                        <li class="mb-2">Política de seguridad</li>
                        <li class="mb-2">Política de cookies</li>
                        <li class="mb-2">Trabaja con nosotros</li>
                        <li class="mb-2">Ubicaciones</li>
                    </ul>

                    <h5 class="fw-bold mt-4 mb-3">Agenda tu cita médica</h5>
                    <p class="mb-2">Agenda tu cita médica: 600 9 600</p>
                    <p class="mb-2">Cuéntanos tu experiencia</p>
                    <p class="mb-0">Portal para prestadores</p>
                </div>

                <div class="col-md-3">
                    <h5 class="fw-bold mb-3">Matriz Guayaquil</h5>
                    <p>
                        Av. Juan Tanca Marengo y Av. Agustín Freire<br />
                        Ycaza Esq. Edificio Veris
                    </p>
                    <p class="mb-4">Teléfono oficinas: 603 2 000</p>

                    <h5 class="fw-bold mb-3">Oficinas Quito</h5>
                    <p>
                        Av. Eloy Alfaro N33 - 400 y Fernando Ayarza
                    </p>
                    <p class="mb-4">Teléfono oficinas: 603 2 000</p>

                    <h5 class="fw-bold mb-3">Oficinas Cuenca</h5>
                    <p>
                        Av. Solano y Remigio Crespo, Centro Médico Veris
                    </p>
                    <p class="mb-0">Teléfono oficinas: 603 2 000</p>
                </div>

                <div class="col-md-3">
                    <h4 class="fw-bold mb-3">
                        Encuentra citas, tratamientos,<br />
                        recetas y tus resultados
                    </h4>

                    <h2 class="fw-bold mb-4" style="color:#76a7ff;">
                        en un solo lugar.
                    </h2>

                    <div class="d-flex gap-3 flex-wrap">
                        <div class="bg-dark rounded-3 px-3 py-2">
                            App Store
                        </div>
                        <div class="bg-dark rounded-3 px-3 py-2">
                            Google Play
                        </div>
                    </div>
                </div>

                <div class="col-md-3 text-center">
                    <img src="~/Imagenes/MedicosVeris.jpeg"
                         alt="VERIS"
                         class="img-fluid shadow"
                         style="max-height:250px; width:100%; object-fit:cover; border-radius:24px; border:4px solid rgba(255,255,255,0.25);" />
                </div>

            </div>

            <hr class="border-light opacity-25 my-4" />

            <div class="text-center small opacity-75">
                &copy; @DateTime.Now.Year VERIS - Grupo N
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>