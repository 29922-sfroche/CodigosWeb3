@model MoldeMVC_Core.Models.Consultas

@{
    ViewData["Title"] = "Editar consulta";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Editar consulta</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" novalidate>
            <input type="hidden" asp-for="Id" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="MedicoId" class="form-label fw-semibold"></label>
                    <select asp-for="MedicoId" asp-items="ViewBag.MedicoId" class="form-select">
                        <option value="">-- Seleccione médico --</option>
                    </select>
                    <span asp-validation-for="MedicoId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PacienteId" class="form-label fw-semibold"></label>
                    <select asp-for="PacienteId" asp-items="ViewBag.PacienteId" class="form-select">
                        <option value="">-- Seleccione paciente --</option>
                    </select>
                    <span asp-validation-for="PacienteId" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-4">
                    <label asp-for="FechaConsulta" class="form-label fw-semibold"></label>
                    <input asp-for="FechaConsulta" type="date" class="form-control" value="@(Model?.FechaConsulta.ToString("yyyy-MM-dd"))" />
                    <span asp-validation-for="FechaConsulta" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Hi" class="form-label fw-semibold"></label>
                    <select asp-for="Hi" asp-items="ViewBag.Horas" class="form-select">
                        <option value="">-- Seleccione hora inicio --</option>
                    </select>
                    <span asp-validation-for="Hi" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Hf" class="form-label fw-semibold"></label>
                    <select asp-for="Hf" asp-items="ViewBag.HorasFin" class="form-select">
                        <option value="">-- Seleccione hora fin --</option>
                    </select>
                    <span asp-validation-for="Hf" class="text-danger small"></span>
                    <div class="text-danger small mt-1" id="horaFeedback"></div>
                </div>
            </div>

            <div class="mb-3 mt-3">
                <label asp-for="Diagnostico" class="form-label fw-semibold"></label>
                <textarea asp-for="Diagnostico" class="form-control" rows="3" placeholder="Describa el diagnóstico del paciente..."></textarea>
                <span asp-validation-for="Diagnostico" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const form = document.querySelector('form');
            const hi = document.getElementById('Hi');
            const hf = document.getElementById('Hf');
            const error = document.getElementById('horaFeedback');

            form.addEventListener('submit', function (e) {
                if (hi.value && hf.value && hf.value <= hi.value) {
                    e.preventDefault();
                    error.textContent = 'La hora de fin debe ser posterior a la hora de inicio.';
                    hf.classList.add('is-invalid');
                } else {
                    error.textContent = '';
                    hf.classList.remove('is-invalid');
                }
            });
        })();
    </script>
}
