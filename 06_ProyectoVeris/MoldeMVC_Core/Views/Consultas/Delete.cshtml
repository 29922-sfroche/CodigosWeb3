@model MoldeMVC_Core.Models.Consultas

@{
    ViewData["Title"] = "Eliminar consulta";
}

<div class="card border-danger shadow-sm mt-4">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación</h5>
    </div>
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este registro?</p>

        <dl class="row">
            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.FechaConsulta.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Médico</dt>
            <dd class="col-sm-9">@(Model.MedicoNombre ?? "-")</dd>
            <dt class="col-sm-3">Paciente</dt>
            <dd class="col-sm-9">@(Model.PacienteNombre ?? "-")</dd>
            <dt class="col-sm-3">Diagnóstico</dt>
            <dd class="col-sm-9">@Model.Diagnostico</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2"><i class="bi bi-trash"></i> Eliminar</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
        </form>
    </div>
</div>
