@model MoldeMVC_Core.Models.Consultas

@using System.Globalization

@{
    ViewData["Title"] = "Detalle de consulta";
}

@functions {
    private static string FormatearHora(string? hora)
    {
        if (string.IsNullOrWhiteSpace(hora))
        {
            return "-";
        }

        var formatos = new[] { "HH:mm:ss", "HH:mm", "h:mm tt", "hh:mm tt" };
        if (DateTime.TryParseExact(hora, formatos, CultureInfo.GetCultureInfo("en-US"), DateTimeStyles.None, out var fecha))
        {
            return fecha.ToString("h:mm tt", CultureInfo.GetCultureInfo("en-US"));
        }

        return hora;
    }
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Detalle de consulta</h5>
    </div>
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-3">Fecha</dt>
            <dd class="col-sm-9">@Model.FechaConsulta.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-3">Médico</dt>
            <dd class="col-sm-9">@(Model.MedicoNombre ?? "-")</dd>
            <dt class="col-sm-3">Paciente</dt>
            <dd class="col-sm-9">@(Model.PacienteNombre ?? "-")</dd>
            <dt class="col-sm-3">Hora Inicio</dt>
            <dd class="col-sm-9">@FormatearHora(Model.Hi)</dd>
            <dt class="col-sm-3">Hora Fin</dt>
            <dd class="col-sm-9">@FormatearHora(Model.Hf)</dd>
            <dt class="col-sm-3">Diagnóstico</dt>
            <dd class="col-sm-9">@Model.Diagnostico</dd>
        </dl>

        <div class="mt-4 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> Editar</a>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-list"></i> Volver</a>
        </div>
    </div>
</div>
