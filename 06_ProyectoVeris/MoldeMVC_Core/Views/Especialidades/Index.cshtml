@model IEnumerable<MoldeMVC_Core.Models.Especialidades>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.descripcion)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.dias)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.franjaHI)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.franjaHF)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.descripcion)
            </td>
            <td>
                @Html.DisplayFor(model => item.dias)
            </td>
            <td>
                @Html.DisplayFor(model => item.franjaHI)
            </td>
            <td>
                @Html.DisplayFor(model => item.franjaHF)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item._id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item._id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item._id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
