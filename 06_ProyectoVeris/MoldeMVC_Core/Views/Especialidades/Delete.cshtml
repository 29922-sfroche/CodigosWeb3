@model MoldeMVC_Core.Models.Especialidades

@{
    ViewData["Title"] = "Eliminar especialidad";
}

<div class="card border-danger shadow-sm mt-4">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación</h5>
    </div>
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este registro?</p>

        <dl class="row">
            <dt class="col-sm-3">Especialidad</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>
            <dt class="col-sm-3">Días</dt>
            <dd class="col-sm-9">@Model.Dias</dd>
            <dt class="col-sm-3">Hora Inicio</dt>
            <dd class="col-sm-9">@Model.FranjaHI</dd>
            <dt class="col-sm-3">Hora Fin</dt>
            <dd class="col-sm-9">@Model.FranjaHF</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2"><i class="bi bi-trash"></i> Eliminar</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
        </form>
    </div>
</div>
