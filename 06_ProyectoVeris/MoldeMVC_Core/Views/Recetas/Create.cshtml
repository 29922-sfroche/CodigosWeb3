@model MoldeMVC_Core.Models.Recetas

@{
    ViewData["Title"] = "Nueva receta";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-journal-medical"></i> Nueva receta</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post" novalidate>
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            }

            <div class="mb-3">
                <label asp-for="ConsultaId" class="form-label fw-semibold"></label>
                <select asp-for="ConsultaId" asp-items="ViewBag.ConsultaId" class="form-select">
                    <option value="">-- Seleccione consulta --</option>
                </select>
                <span asp-validation-for="ConsultaId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MedicamentoId" class="form-label fw-semibold"></label>
                <select asp-for="MedicamentoId" asp-items="ViewBag.MedicamentoId" class="form-select">
                    <option value="">-- Seleccione medicamento --</option>
                </select>
                <span asp-validation-for="MedicamentoId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label fw-semibold"></label>
                <input asp-for="Cantidad" class="form-control" type="number" min="1" max="999" placeholder="Cantidad de unidades (ej: 2)" />
                <span asp-validation-for="Cantidad" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Guardar</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
