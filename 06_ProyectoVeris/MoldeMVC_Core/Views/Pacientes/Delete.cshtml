@model MoldeMVC_Core.Models.Pacientes

@{
    ViewData["Title"] = "Eliminar paciente";
}

<div class="card border-danger shadow-sm mt-4">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar eliminación</h5>
    </div>
    <div class="card-body">
        <p>¿Está seguro de que desea eliminar este registro?</p>

        <div class="text-center mb-3">
            <img src="/imaganes/pacientes/@(string.IsNullOrWhiteSpace(Model.Foto) ? "default-user.png" : Model.Foto)"
                 class="img-thumbnail" style="max-height:140px;" alt="@Model.Nombre" />
        </div>

        <dl class="row">
            <dt class="col-sm-3">Nombre</dt>
            <dd class="col-sm-9">@Model.Nombre</dd>
            <dt class="col-sm-3">Cédula</dt>
            <dd class="col-sm-9">@Model.Cedula</dd>
            <dt class="col-sm-3">Género</dt>
            <dd class="col-sm-9">@Model.Genero</dd>
        </dl>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2"><i class="bi bi-trash"></i> Eliminar</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Cancelar</a>
        </form>
    </div>
</div>
