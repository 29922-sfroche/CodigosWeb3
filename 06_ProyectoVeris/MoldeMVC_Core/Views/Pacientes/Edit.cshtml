@model MoldeMVC_Core.Models.Pacientes

@{
    ViewData["Title"] = "Editar paciente";
}

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Editar paciente</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data" novalidate>
            <input type="hidden" asp-for="Id" />
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            }

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Juan Carlos Pérez López" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cedula" class="form-label fw-semibold"></label>
                <input asp-for="Cedula" class="form-control" id="inputCedula" maxlength="10" placeholder="Ingrese 10 dígitos de la cédula" />
                <div id="cedulaFeedback" class="mt-1"></div>
                <span asp-validation-for="Cedula" class="text-danger small"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Edad" class="form-label fw-semibold"></label>
                    <input asp-for="Edad" type="number" min="0" max="120" class="form-control" placeholder="35" />
                    <span asp-validation-for="Edad" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Genero" class="form-label fw-semibold"></label>
                    <select asp-for="Genero" class="form-select">
                        <option value="">-- Seleccione género --</option>
                        <option value="Masculino">Masculino</option>
                        <option value="Femenino">Femenino</option>
                        <option value="Otro">Otro</option>
                    </select>
                    <span asp-validation-for="Genero" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Estatura" class="form-label fw-semibold"></label>
                    <input asp-for="Estatura" type="number" min="50" max="250" class="form-control" placeholder="170" />
                    <small class="text-muted">Ingrese en centímetros</small>
                    <span asp-validation-for="Estatura" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-6">
                    <label asp-for="Peso" class="form-label fw-semibold"></label>
                    <input asp-for="Peso" type="number" step="0.1" min="1" max="300" class="form-control" placeholder="65.5" />
                    <small class="text-muted">Ingrese en kilogramos</small>
                    <span asp-validation-for="Peso" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FotoFile" class="form-label fw-semibold"></label>
                    <input type="file" asp-for="FotoFile" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
                    <small class="text-muted">Formatos: JPG, PNG, GIF. Máximo 2 MB.</small>
                    <span asp-validation-for="FotoFile" class="text-danger small"></span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Foto))
            {
                <div class="mt-3">
                    <img src="/imaganes/pacientes/@Model.Foto" class="img-thumbnail" style="max-height:120px;" alt="Foto actual" />
                    <p class="text-muted small mb-0">Foto actual: @Model.Foto</p>
                </div>
            }

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary" id="btnSubmit" disabled><i class="bi bi-save"></i> Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (function () {
            const inputCedula = document.getElementById('inputCedula');
            const feedback = document.getElementById('cedulaFeedback');
            const btnSubmit = document.getElementById('btnSubmit');

            function validarCedulaEC(cedula) {
                if (!/^\d{10}$/.test(cedula)) return false;
                const provincia = parseInt(cedula.substring(0, 2), 10);
                if (provincia < 1 || provincia > 24) return false;
                const tercerDigito = parseInt(cedula[2], 10);
                if (tercerDigito >= 6) return false;
                const coefs = [2, 1, 2, 1, 2, 1, 2, 1, 2];
                let suma = 0;
                for (let i = 0; i < 9; i++) {
                    let valor = parseInt(cedula[i], 10) * coefs[i];
                    if (valor >= 10) valor -= 9;
                    suma += valor;
                }
                const verificador = (10 - (suma % 10)) % 10;
                return verificador === parseInt(cedula[9], 10);
            }

            function actualizarEstado() {
                const val = inputCedula.value.trim();
                if (val.length === 0) {
                    feedback.innerHTML = '';
                    btnSubmit.disabled = true;
                    inputCedula.classList.remove('is-valid', 'is-invalid');
                    return;
                }
                if (validarCedulaEC(val)) {
                    feedback.innerHTML = '<span class="text-success"><i class="bi bi-check-circle-fill"></i> Cédula válida.</span>';
                    inputCedula.classList.add('is-valid');
                    inputCedula.classList.remove('is-invalid');
                    btnSubmit.disabled = false;
                } else {
                    feedback.innerHTML = '<span class="text-danger"><i class="bi bi-x-circle-fill"></i> Cédula ecuatoriana no válida.</span>';
                    inputCedula.classList.add('is-invalid');
                    inputCedula.classList.remove('is-valid');
                    btnSubmit.disabled = true;
                }
            }

            inputCedula.addEventListener('keypress', function (e) {
                if (!/\d/.test(e.key)) e.preventDefault();
            });
            inputCedula.addEventListener('input', actualizarEstado);
            actualizarEstado();
        })();
    </script>
}
