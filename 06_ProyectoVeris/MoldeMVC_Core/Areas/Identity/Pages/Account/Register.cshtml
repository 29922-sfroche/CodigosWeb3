@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<style>
    .bg-veris {
        background: linear-gradient(135deg, #4f84ef, #34c9d4);
    }

    .btn-veris {
        background-color: #4f84ef;
        color: white;
        border: none;
        transition: all 0.3s;
    }

        .btn-veris:hover {
            background-color: #34c9d4;
            color: white;
        }

    .img-register-veris {
        max-height: 280px;
        border-radius: 20px;
        object-fit: cover;
    }
</style>

<main aria-labelledby="title" class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="row align-items-stretch shadow-lg rounded-4 overflow-hidden bg-white">

                <div class="col-md-6 p-4 p-md-5 d-flex flex-column justify-content-center">
                    <section id="registerFormSection">
                        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            <h2 id="title" class="fw-bold mb-1" style="color:#4f84ef;">@ViewData["Title"]</h2>
                            <h6 class="text-muted mb-4">Cree una cuenta nueva.</h6>

                            <hr class="mb-4" />

                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="Input.UserName" class="form-label fw-semibold">Usuario</label>
                                <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" placeholder="Ingrese su usuario" />
                                <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Email" class="form-label fw-semibold">Correo Electrónico</label>
                                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="Ingrese su correo" />
                                <span asp-validation-for="Input.Email" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label fw-semibold">Contraseña</label>
                                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Ingrese su contraseña" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirmar Contraseña</label>
                                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirme su contraseña" />
                                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <button id="registerSubmit" type="submit" class="btn btn-veris px-4 py-2 fw-bold w-100">
                                    Registrarse
                                </button>
                            </div>
                        </form>
                    </section>
                </div>

                <div class="col-md-6 d-flex justify-content-center align-items-center p-4 p-md-5"
                     style="background:linear-gradient(135deg,#4f83f1,#2cc8c8);">
                    <div class="text-center text-white">

                        <h3 class="mb-4 fw-bold">Bienvenido a VERIS</h3>

                        <img src="~/Imagenes/RegistroVeris.jpeg"
                             alt="Registro VERIS"
                             class="img-fluid rounded-4 shadow-lg mb-4 img-register-veris"
                             style="width:200px; height:260px; object-fit:cover; border:4px solid rgba(255,255,255,0.8);" />

                        <p class="mb-0 fs-6 px-2 opacity-75">
                            Regístrate para agendar citas médicas y acceder a nuestros servicios de salud.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}